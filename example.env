# Database (Prisma + PostgreSQL via Neon on Vercel)
# Use the POOLED connection string for DATABASE_URL (app runtime + Prisma client).
# Neon prints both: pooled (-pooler host) and non-pooled. Copy them from the
# Vercel dashboard (equipe project → Storage → equipe-db → .env.local tab).
DATABASE_URL=postgresql://user:password@-pooler.region.aws.neon.tech/neondb?sslmode=require

# DIRECT_URL must be the NON-POOLED connection string (no -pooler host).
# Prisma uses it for `migrate deploy` (needs a direct connection).
DIRECT_URL=postgresql://user:password@.region.aws.neon.tech/neondb?sslmode=require

# Auth.js v5
AUTH_SECRET=generate-with: openssl rand -base64 32
# Set AUTH_URL only locally. On Vercel, LEAVE THIS UNSET — Auth.js v5 auto-derives the URL from VERCEL_URL.
AUTH_URL=http://localhost:3000

# OAuth Providers (optional — not required for the demo)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# App Configuration
NEXT_PUBLIC_BASE_URL=http://localhost:3000
