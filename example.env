# Database (Prisma + PostgreSQL)
# Local: a local Postgres instance.
# Production: use Vercel Postgres — copy the pooled connection string from the Vercel dashboard.
DATABASE_URL=postgresql://user:password@localhost:5432/equipe?schema=public

# Auth.js v5
AUTH_SECRET=generate-with: openssl rand -base64 32
# Set AUTH_URL only locally. On Vercel, LEAVE THIS UNSET — Auth.js v5 auto-derives the URL from VERCEL_URL.
AUTH_URL=http://localhost:3000

# OAuth Providers (optional — not required for the demo)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# App Configuration
NEXT_PUBLIC_BASE_URL=http://localhost:3000
